{
  "type": "module",
  "version": "0.0.6",
  "scripts": {
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "workflows.deploy.test": "act -W ./.github/workflows/deploy.yml --secret-file ./.github/.secrets.local",
    "lint": "eslint . && stylelint \"src/**/*.{css,astro}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,astro}\" --fix",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.{css,astro}\"",
    "typecheck": "astro check",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:report": "playwright show-report"
  },
  "overrides": {
    "vitefu": "1.1.3",
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.58.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.2.3",
    "@typescript-eslint/parser": "^8.62.0",
    "astro": "^5.17.1",
    "astrobook": "^0.12.3",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-simple-html": "^1.1.0"
  },
  "dependencies": {
    "meowsonry-layout": "^0.0.3"
  }
}
