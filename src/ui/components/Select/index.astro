---
interface Props {
  id: string;
  label: string;
  labelHidden?: boolean;
  placeholder?: string;
  value?: string;
  [key: string]: unknown;
}

const {
  id,
  label,
  labelHidden,
  placeholder,
  value,
  class: className,
  ...rest
} = Astro.props;
---

<style>
  @layer ui {
    .select {
      display: grid;
      gap: var(--space-2);
      color: var(--color-text-primary);
    }

    .select__label {
      font-size: var(--font-size-2);
      font-weight: 500;
      line-height: var(--font-size-2-line-height);
    }

    .select__label_visuallyHidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
      border: 0;
    }

    .select__controlWrapper {
      position: relative;
    }

    .select__control {
      width: 100%;
      padding: var(--space-3) calc(var(--space-9) + var(--space-6)) var(--space-3)
        var(--space-4);
      cursor: pointer;
      appearance: none;
      color: var(--color-control-text);
      border: 1px solid var(--color-control-border);
      border-radius: var(--space-2);
      outline: none;
      background-color: var(--color-control-bg);
      font: inherit;
      line-height: var(--font-size-3-line-height);
      transition:
        border-color var(--transition-duration-1) ease,
        background-color var(--transition-duration-1) ease;
    }

    .select__control:focus-visible {
      border-color: var(--color-control-focus);
      outline: 2px solid var(--color-control-focus);
      outline-offset: var(--space-1);
    }

    .select__control:disabled {
      cursor: not-allowed;
      color: var(--color-control-disabled-text);
      background-color: var(--color-control-disabled-bg);
    }

    .select__control:hover:not(:disabled) {
      border-color: var(--color-control-border-hover);
    }

    .select__indicator {
      position: absolute;
      top: 50%;
      right: var(--space-4);
      width: var(--space-3);
      height: var(--space-3);
      pointer-events: none;
      border-right: 1px solid currentcolor;
      border-bottom: 1px solid currentcolor;
      color: var(--color-control-text);
      transform: translateY(-65%) rotate(45deg);
    }

    .select__control:disabled + .select__indicator {
      color: var(--color-control-disabled-text);
    }
  }
</style>

<label class:list={["select", className]} for={id}>
  <span class:list={["select__label", labelHidden && "select__label_visuallyHidden"]}>
    {label}
  </span>
  <span class="select__controlWrapper">
    <select id={id} class="select__control" value={value} {...rest}>
      {placeholder && (
        <option value="" disabled selected={value === undefined}>
          {placeholder}
        </option>
      )}
      <slot />
    </select>
    <span class="select__indicator" aria-hidden="true"></span>
  </span>
</label>
