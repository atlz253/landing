---
import {
  BUTTON_SIZE_TO_CLASS,
  type ButtonSize,
} from "../../../styles/constants";

interface Props {
  size?: ButtonSize;
  [key: string]: unknown;
}

const { size, class: className, ...rest } = Astro.props;
---

<button
  class:list={["button", size && BUTTON_SIZE_TO_CLASS[size], className]}
  {...rest}
>
  <slot />
</button>
