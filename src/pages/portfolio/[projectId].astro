---
import Layout from "../../components/Layout.astro";
import Head from "../../components/Head.astro";
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";
import Image from "astro/components/Image.astro";
import ButtonLink from "../../ui/components/ButtonLink/index.astro";
import { getPortfolioImage } from "../../features/viewPortfolio/collections/portfolio/getPortfolioImage";
import Lightbox from "../../components/Lightbox/index.astro";
import FullscreenIframe from "../../features/viewPortfolio/components/FullscreenIframe/index.astro";
import TechnologyChips from "../../features/viewPortfolio/components/TechnologyChips/index.astro";

const { projectId } = Astro.params;

export async function getStaticPaths() {
  const projects = await getCollection("portfolio");

  return projects
    .filter((project) => project.body?.trim())
    .map(({ id }) => ({
      params: { projectId: id },
    }));
}

const project = (await getCollection("portfolio")).find(
  (p) => p.id === projectId && p.body?.trim(),
);

if (!project) {
  return Astro.redirect("/404");
}

const { Content } = await render(project);
const projectDescription = Array.isArray(project.data.description)
  ? project.data.description.join(" ")
  : project.data.description;

const lightboxImages = project.data.images
  ? (
      await Promise.all(
        project.data.images.map(async (image) => {
          const resolved = getPortfolioImage(image);
          if (!resolved) return null;
          try {
            const full = await getImage({
              src: resolved,
              height: 1200,
              format: "webp",
            });
            return { src: full.src, alt: project.data.title };
          } catch {
            return null;
          }
        }),
      )
    ).filter((x): x is { src: string; alt: string } => x !== null)
  : [];
---

<style>
  .contentWrapper {
    display: flex;
    justify-content: center;
  }

  .content {
    display: flex;
    width: 100%;
    max-width: var(--content-width-max);
    flex-direction: column;
    gap: var(--space-6);
  }

  .images {
    width: 100%;
    display: flex;
    overflow: auto hidden;
    padding: var(--space-4);
    gap: var(--space-4);
  }

  .projectImage {
    box-shadow: var(--box-shadow-1);
    cursor: zoom-in;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>

<html lang="ru">
  <head>
    <Head
      title={project.data.title}
      description={projectDescription ?? `Проект «${project.data.title}» в портфолио Федора Алексеева.`}
    />
  </head>
  <Layout>
    <div class="contentWrapper">
      <div class="content" data-portfolio-content>
        <h1>{project.data.title}</h1>
        {
          project.data.technologies && (
            <TechnologyChips technologies={project.data.technologies} />
          )
        }
        {
          project.data.href && (
            <div class="actions">
              <ButtonLink href={project.data.href}>Открыть проект</ButtonLink>
            </div>
          )
        }
        <Content />
      </div>
    </div>
    {
      project.data.images && project.data.images.length > 0 && (
        <>
          <h2>Фото</h2>
          <div class="images">
            {project.data.images.map((image, i) => (
              <Image
                src={getPortfolioImage(image)}
                alt={project.data.title}
                height={300}
                class="projectImage"
                data-lightbox-index={i}
              />
            ))}
          </div>
        </>
      )
    }
    {lightboxImages.length > 0 && <Lightbox images={lightboxImages} />}
    <FullscreenIframe />
  </Layout>
</html>
