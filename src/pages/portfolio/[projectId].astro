---
import Layout from "../../components/Layout.astro";
import Head from "../../components/Head.astro";
import { getCollection, render } from "astro:content";
import Image from "astro/components/Image.astro";
import ButtonLink from "../../ui/components/ButtonLink/index.astro";
import { getPortfolioImage } from "../../features/viewPortfolio/collections/portfolio/getPortfolioImage";

const { projectId } = Astro.params;

export async function getStaticPaths() {
  const projects = await getCollection("portfolio");

  return projects
    .filter((project) => project.body?.trim())
    .map(({ id }) => ({
      params: { projectId: id },
    }));
}

const project = (await getCollection("portfolio")).find(
  (p) => p.id === projectId && p.body?.trim(),
);

if (!project) {
  return Astro.redirect("/404");
}

const { Content } = await render(project);
---

<style>
  .contentWrapper {
    display: flex;
    justify-content: center;
  }

  .content {
    display: flex;
    width: 100%;
    max-width: var(--content-width-max);
    flex-direction: column;
    gap: var(--space-6);
  }

  .images {
    width: 96vw;
    display: flex;
    overflow-y: auto;
    padding: var(--space-4);
    gap: var(--space-4);
  }

  .projectImage {
    box-shadow: var(--box-shadow-1);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>

<html lang="ru">
  <head>
    <Head title={project.data.title} />
  </head>
  <Layout>
    <div class="contentWrapper">
      <div class="content">
        <h1>{project.data.title}</h1>
        {
          project.data.href && (
            <div class="actions">
              <ButtonLink href={project.data.href}>Открыть проект</ButtonLink>
            </div>
          )
        }
        <Content />
      </div>
    </div>
    {
      project.data.images && project.data.images.length > 0 && (
        <>
          <h2>Фото</h2>
          <div class="images">
            {project.data.images.map((image) => (
              <Image
                src={getPortfolioImage(image)}
                alt={project.data.title}
                height={300}
                class="projectImage"
              />
            ))}
          </div>
        </>
      )
    }
  </Layout>
</html>
