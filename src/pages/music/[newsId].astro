---
import Layout from "../../components/Layout.astro";
import Head from "../../components/Head.astro";
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";
import Image from "astro/components/Image.astro";
import type { News } from "../../features/viewNews/schemas";
import YandexCloudVideo from "../../integrations/yandexCloud/cloudVideo/components/YandexCloudVideo.astro";
import { getMusicNewsImage } from "../../features/viewNews/collections/musicNews/getMusicNewsImage";
import VKVideo from "../../integrations/vk/components/VKVideo.astro";
import Lightbox from "../../components/Lightbox/index.astro";

const { newsId } = Astro.params;

export async function getStaticPaths() {
  const newsCollection = await getCollection("musicNews");

  return newsCollection.map(({ id }) => ({
    params: { newsId: id },
  }));
}

const news = (await getCollection("musicNews")).find((n) => n.id === newsId);

if (!news) {
  return Astro.redirect("/404");
}

const newsData: News = news.data;

const lightboxImages = newsData.images
  ? (
      await Promise.all(
        newsData.images.map(async (image) => {
          const resolved = getMusicNewsImage(image);
          if (!resolved) return null;
          try {
            const full = await getImage({
              src: resolved,
              height: 1200,
              format: "webp",
            });
            return { src: full.src, alt: newsData.title };
          } catch {
            return null;
          }
        }),
      )
    ).filter((x): x is { src: string; alt: string } => x !== null)
  : [];

const { Content } = await render(news);
---

<style>
  .contentWrapper {
    display: flex;
    justify-content: center;
  }

  .content {
    width: 100%;
    max-width: var(--content-width-max);
  }

  .content :global(details) {
    padding: var(--space-3);
    border-radius: var(--space-4);
    border: 1px solid var(--color-grey-8);
  }

  .content :global(summary) {
    cursor: pointer;
    user-select: none;
  }

  .content :global(summary::marker) {
    color: var(--color-grey-8);
  }

  .content :global(p + p) {
    margin-top: var(--space-4);
  }

  .images,
  .videos {
    width: 96vw;
    display: flex;
    overflow-y: auto;
    padding: var(--space-4);
    gap: var(--space-4);
  }

  .image {
    box-shadow: var(--box-shadow-1);
    cursor: zoom-in;
  }
</style>

<html lang="ru">
  <head>
    <Head title={newsData.title} />
  </head>
  <Layout>
    <div class="contentWrapper">
      <div class="content">
        <h1>{newsData.title}</h1>
        <Content />
      </div>
    </div>
    {
      newsData.images && (
        <>
          <h2>Фото</h2>
          <div class="images">
            {newsData.images.map((i, index) => (
              <Image
                src={getMusicNewsImage(i)}
                alt={newsData.title}
                height={300}
                class="image"
                data-lightbox-index={index}
              />
            ))}
          </div>
        </>
      )
    }
    {
      (newsData.yandexVideos || newsData.vkVideos) && (
        <>
          <h2>Видео</h2>
          <div class="videos">
            {newsData.yandexVideos?.map((v) => (
              <YandexCloudVideo src={v} height={300} width={500} />
            ))}
            {newsData.vkVideos?.map((v) => (
              <VKVideo src={v} height={300} width={500} />
            ))}
          </div>
        </>
      )
    }
    <small>{newsData.date.toLocaleDateString("ru-RU")}</small>
    {lightboxImages.length > 0 && <Lightbox images={lightboxImages} />}
  </Layout>
</html>
