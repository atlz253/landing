---
import Layout from "../../components/Layout.astro";
import Head from "../../components/Head.astro";
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";
import Image from "astro/components/Image.astro";
import type { News } from "../../features/viewNews/schemas";
import YandexCloudVideo from "../../integrations/yandexCloud/cloudVideo/components/YandexCloudVideo.astro";
import { getMusicNewsImage } from "../../features/viewNews/collections/musicNews";
import VKVideo from "../../integrations/vk/components/VKVideo.astro";
import Lightbox from "../../components/Lightbox/index.astro";
import AudioPlayer from "../../features/viewNews/components/AudioPlayer/index.astro";

const { newsId } = Astro.params;

export async function getStaticPaths() {
  const newsCollection = await getCollection("musicNews");

  return newsCollection.map(({ id }) => ({
    params: { newsId: id },
  }));
}

const news = (await getCollection("musicNews")).find((n) => n.id === newsId);

if (!news) {
  return Astro.redirect("/404");
}

const newsData: News = news.data;

const audioGlob = import.meta.glob<{ default: string }>(
  "/collections/musicNews/*.(mp3|wav|ogg|flac|m4a|aac|opus)",
);

async function resolveAudio(path: string): Promise<string | undefined> {
  for (const [key, loader] of Object.entries(audioGlob)) {
    if (key.replace(/\\/g, "/") === path) {
      try {
        return (await loader()).default;
      } catch {
        return;
      }
    }
  }
}

const lightboxImages = newsData.images
  ? (
      await Promise.all(
        newsData.images.map(async (image) => {
          const resolved = getMusicNewsImage(image);
          if (!resolved) return null;
          try {
            const full = await getImage({
              src: resolved,
              height: 1200,
              format: "webp",
            });
            return { src: full.src, alt: newsData.title };
          } catch {
            return null;
          }
        }),
      )
    ).filter((x): x is { src: string; alt: string } => x !== null)
  : [];

const audioTracks = newsData.audio
  ? (
      await Promise.all(
        newsData.audio.map(async (track) => {
          const sources = (
            await Promise.all(
              track.src.map(async (s) => {
                const resolved = await resolveAudio(s);
                return resolved ?? s;
              }),
            )
          ).filter((x): x is string => x !== null);
          if (sources.length === 0) return null;
          return { src: sources, title: track.title };
        }),
      )
    ).filter(
      (x): x is { src: string[]; title: string | undefined } => x !== null,
    )
  : [];

const { Content } = await render(news);
---

<style>
  .contentWrapper {
    display: flex;
    justify-content: center;
  }

  .content {
    width: 100%;
    max-width: var(--content-width-max);
  }

  .content :global(details) {
    padding: var(--space-3);
    border-radius: var(--space-4);
    border: 1px solid var(--color-text-secondary);
  }

  .content :global(summary) {
    cursor: pointer;
    user-select: none;
  }

  .content :global(summary::marker) {
    color: var(--color-text-secondary);
  }

  .content :global(p + p) {
    margin-top: var(--space-4);
  }

  .images,
  .videos {
    width: 100%;
    display: flex;
    overflow: auto hidden;
    padding: var(--space-4);
    gap: var(--space-4);
  }

  .image {
    box-shadow: var(--box-shadow-1);
    cursor: zoom-in;
  }
</style>

<html lang="ru">
  <head>
    <Head
      title={newsData.title}
      description={`Музыкальная публикация «${newsData.title}» на сайте Федора Алексеева.`}
    />
  </head>
  <Layout>
    <div class="contentWrapper">
      <div class="content">
        <h1>{newsData.title}</h1>
        <Content />
      </div>
    </div>
    {audioTracks.length > 0 && (
      <div class="contentWrapper">
        <div class="content">
          <h2>Аудио</h2>
          <AudioPlayer tracks={audioTracks} />
        </div>
      </div>
    )}
    {
      newsData.images && (
        <>
          <h2>Фото</h2>
          <div class="images">
            {newsData.images.map((i, index) => (
              <Image
                src={getMusicNewsImage(i)}
                alt={newsData.title}
                height={300}
                class="image"
                data-lightbox-index={index}
              />
            ))}
          </div>
        </>
      )
    }
    {
      (newsData.yandexVideos || newsData.vkVideos) && (
        <>
          <h2>Видео</h2>
          <div class="videos">
            {newsData.yandexVideos?.map((v) => (
              <YandexCloudVideo src={v} height={300} width={500} />
            ))}
            {newsData.vkVideos?.map((v) => (
              <VKVideo src={v} height={300} width={500} />
            ))}
          </div>
        </>
      )
    }
    <small>{newsData.date.toLocaleDateString("ru-RU")}</small>
    {lightboxImages.length > 0 && <Lightbox images={lightboxImages} />}
  </Layout>
</html>
