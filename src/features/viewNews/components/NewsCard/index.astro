---
import Image from "astro/components/Image.astro";
import type { CollectionEntry } from "astro:content";
import YandexCloudVideo from "../../../../integrations/yandexCloud/cloudVideo/components/YandexCloudVideo.astro";
import { getNewsCardPreviewType } from "./utils";
import { getMusicNewsImage } from "../../collections/musicNews/getMusicNewsImage";
import ButtonLink from "../../../../ui/components/ButtonLink/index.astro";

interface Props {
  news: CollectionEntry<"musicNews">;
  autoplay?: boolean;
}

const { news, autoplay = false } = Astro.props;

const newsData = news.data;
const newsCardType = getNewsCardPreviewType(newsData);
---

<style>
  .news {
    display: flex;
    width: fit-content;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    border: 1px solid var(--color-grey-3);
    border-radius: var(--space-4);
    background-color: var(--color-grey-1);
  }

  .news[data-meowsonry-prevent-flick] {
    animation: meowsonry-fade-in 220ms ease both;
    animation-delay: calc(var(--meowsonry-index) * 24ms);
  }

  @keyframes meowsonry-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .news__title {
    font-size: var(--font-size-4);
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
  }

  .news__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: var(--space-2);
    background-color: var(--color-grey-3);
  }

  .news__video {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--color-grey-3);
    border-radius: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: var(--font-size-2);
  }

  .news__content,
  .news__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .news__right {
    align-items: end;
  }

  .news__link {
    width: fit-content;
  }
</style>

<div class="news">
  <div class="news__content">
    {
      newsCardType === "images" && newsData.images && newsData.images[0] && (
        <Image
          src={getMusicNewsImage(newsData.images[0])}
          alt={newsData.title}
          class="news__image"
        />
      )
    }
    {
      newsCardType === "yandexVideos" &&
        newsData.yandexVideos &&
        newsData.yandexVideos[0] && (
          <YandexCloudVideo
            class="news__video"
            src={newsData.yandexVideos[0]}
            autoplay={autoplay}
            mute
          />
        )
    }
    <h2 class="news__title">{newsData.title}</h2>
    <div class="news__right">
      <ButtonLink href={`/music/${news.id}`} class="news__link"
        >Подробнее</ButtonLink
      >
      <small>{new Date(newsData.date).toLocaleDateString("ru-RU")}</small>
    </div>
  </div>
</div>
