---
import { getCollection } from "astro:content";
import TechnologyFilter from "../../features/viewPortfolio/components/TechnologyFilter/index.astro";
import PortfolioCard from "./components/PortfolioCard.astro";

const projects = (await getCollection("portfolio")).sort(
  (a, b) =>
    b.data.date.getTime() - a.data.date.getTime() ||
    a.id.localeCompare(b.id),
);
---

<style>
  #portfolio {
    --portfolio-gap: var(--space-6);

    width: 100%;
    visibility: hidden;
  }

  .portfolioEmpty {
    margin: var(--space-6) 0;
    color: var(--color-text-secondary);
  }

  .tile {
    box-sizing: border-box;
    width: 100%;
  }

  .tile[hidden] {
    display: none;
  }

  .tile[data-meowsonry-prevent-flick] {
    animation: meowsonry-fade-in var(--transition-duration-3) ease both;
    animation-delay: calc(var(--meowsonry-index) * 24ms);
  }

  @keyframes meowsonry-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (width >= 720px) {
    .tile {
      width: calc((100% - var(--portfolio-gap)) / 2);
    }
  }

  @media (width >= 1440px) {
    .tile {
      width: calc((100% - var(--portfolio-gap) * 3) / 3);
    }
  }

  @media (width >= 1680px) {
    .tile {
      width: calc((100% - var(--portfolio-gap) * 4) / 4);
    }
  }
</style>

<section>
  <TechnologyFilter />
  <p class="portfolioEmpty" hidden data-portfolio-empty>
    Нет проектов с выбранным сочетанием технологий.
  </p>
  <div id="portfolio">
    {
      projects.map((project) => (
        <PortfolioCard
          project={project}
          class:list={["tile", "tile_" + project.id]}
        />
      ))
    }
  </div>
</section>

<script>
  import { autoUpdate, gap, meowsonry, preventFlick } from "meowsonry-layout";

  let cancelUpdate: undefined | (() => void);

  const clearPortfolioLayout = (container: HTMLElement) => {
    container.style.height = "";
    container.style.position = "";

    Array.from(container.children).forEach((child) => {
      if (!(child instanceof HTMLElement)) return;

      Object.assign(child.style, {
        left: "",
        position: "",
        top: "",
      });
    });
  };

  const updatePortfolioLayout = (container: HTMLElement) => {
    const cards = Array.from(container.children).filter(
      (child): child is HTMLElement => child instanceof HTMLElement,
    );
    const visibleCards = cards.filter((card) => !card.hidden);

    if (visibleCards.length === 0) {
      container.style.height = "0";
      return;
    }

    if (visibleCards.length === cards.length) {
      meowsonry({ container, middleware: [preventFlick(), gap(12)] });
      return;
    }

    container.replaceChildren(...visibleCards);
    meowsonry({ container, middleware: [preventFlick(), gap(12)] });
    container.replaceChildren(...cards);
  };

  document.addEventListener("astro:page-load", () => {
    const container = document.querySelector("#portfolio") as HTMLElement;
    if (!container) return;

    cancelUpdate?.();
    clearPortfolioLayout(container);

    cancelUpdate = autoUpdate(container, () =>
      updatePortfolioLayout(container),
    );

    container.addEventListener("portfolio:filter-change", () => {
      updatePortfolioLayout(container);
    });
  });

  document.addEventListener("astro:before-preparation", () => {
    cancelUpdate?.();
    cancelUpdate = undefined;

    const container = document.querySelector("#portfolio") as HTMLElement;
    if (container) {
      clearPortfolioLayout(container);
    }
  });
</script>
