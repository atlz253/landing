---
import { Code } from "astro:components";
import Image from "astro/components/Image.astro";
import type { CollectionEntry } from "astro:content";
import Card from "../../Card.astro";
import List from "../../List.astro";
import Link from "../../Link.astro";
import PrettyParagraph from "../../PrettyParagraph.astro";
import ButtonLink from "../../../ui/components/ButtonLink/index.astro";
import { getPortfolioImage } from "../../../features/viewPortfolio/collections/portfolio/getPortfolioImage";
import TechnologyChips from "../../../features/viewPortfolio/components/TechnologyChips/index.astro";

interface Props {
  project: CollectionEntry<"portfolio">;
  [key: string]: unknown;
}

const { project, class: className, ...rest } = Astro.props;

const normalizeDescription = (description: unknown) =>
  Array.isArray(description)
    ? description.filter((paragraph): paragraph is string => typeof paragraph === "string")
    : typeof description === "string"
      ? [description]
      : [];

const frontmatter = project.rendered?.metadata?.frontmatter as
  | { description?: unknown }
  | undefined;

const description = normalizeDescription(
  project.data.description ?? frontmatter?.description,
);
const actionHref = project.body?.trim()
  ? `/portfolio/${project.id}`
  : project.data.href;
const previewImage = project.data.images?.[0];
---

<style>
  .portfolioCard {
    transition: background-color var(--transition-duration-2) linear;
  }

  .portfolioCard :global(ul) {
    list-style: none;
    padding-inline-start: 0;
  }

  .portfolioCardWrapper {
    display: flex;
    flex-direction: column;
    color: var(--color-text-primary);
  }

  .portfolioCard__actions {
    align-self: flex-end;
    display: flex;
    margin-left: auto;
    margin-top: auto;
  }

  .portfolioImage {
    width: 100%;
    height: auto;
    border-radius: var(--space-3);
  }

  .rondoCode {
    display: none;
  }

  @media (width >= 432px) {
    .rondoCode {
      display: block;
    }
  }
</style>

<div class:list={["portfolioCardWrapper", className]} {...rest}>
  <Card class="portfolioCard">
    <h2>{project.data.title}</h2>
    {project.data.technologies && (
      <TechnologyChips technologies={project.data.technologies} limit={5} />
    )}
    {
      previewImage && (
        <Image
          src={getPortfolioImage(previewImage)}
          alt={project.data.title}
          class="portfolioImage"
        />
      )
    }
    {description.map((paragraph) => <PrettyParagraph>{paragraph}</PrettyParagraph>)}
    {
      project.data.items && (
        <List>
          {project.data.items.map((item) => (
            <li>
              -{" "}
              {item.href ? <Link href={item.href}>{item.text}</Link> : item.text}
            </li>
          ))}
        </List>
      )
    }
    {
      project.data.code && (
        <Code
          code={project.data.code.value}
          lang={project.data.code.lang}
          theme="github-light"
          class:list={[project.id === "rondo" && "rondoCode"]}
        />
      )
    }
    {
      actionHref && (
        <div class="portfolioCard__actions">
          <ButtonLink href={actionHref}>Подробнее</ButtonLink>
        </div>
      )
    }
  </Card>
</div>
