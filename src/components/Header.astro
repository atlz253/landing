---
import Link from "./Link.astro";
---

<style>
  .header {
    top: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) var(--space-6);
    background-color: var(--color-bg);
    box-shadow: var(--box-shadow-1);
    position: sticky;
    z-index: var(--z-index-5);
    width: 100%;
    box-sizing: border-box;
  }

  .nav-container {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .nav {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    align-items: center;
  }

  .nav-link {
    text-decoration: none;
    color: var(--color-text-secondary);
    font-weight: 500;
    padding: var(--space-2) var(--space-3);
    border-radius: 4px;
    transition:
      color,
      background-color var(--transition-duration-2) ease;
  }

  .nav-link:hover {
    color: var(--color-link);
    background-color: var(--color-bg-hover);
  }

  .nav-link.active {
    color: var(--color-link);
    font-weight: bold;
  }

  .theme-toggle {
    position: absolute;
    right: var(--space-6);
    top: 50%;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: none;
    border-radius: var(--space-9);
    background: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: color var(--transition-duration-1) ease,
                background-color var(--transition-duration-1) ease;
  }

  .theme-toggle:hover {
    color: var(--color-link);
    background-color: var(--color-bg-hover);
  }

  .theme-toggle-icon {
    width: 20px;
    height: 20px;
  }

  .theme-toggle-icon--sun {
    display: none;
  }

  :global([data-theme="dark"]) .theme-toggle-icon--moon {
    display: none;
  }

  :global([data-theme="dark"]) .theme-toggle-icon--sun {
    display: block;
  }
</style>

<header class="header">
  <div class="nav-container">
    <nav class="nav">
      <Link href="/" class="nav-link">Главная</Link>
      <Link href="/music" class="nav-link">Музыка</Link>
      <Link
        href="https://my-digital-garden-sand-delta.vercel.app/"
        class="nav-link">База знаний</Link
      >
    </nav>
    <button class="theme-toggle" aria-label="Переключить тему">
      <svg class="theme-toggle-icon theme-toggle-icon--sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="theme-toggle-icon theme-toggle-icon--moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </div>
</header>

<script>
  function toggleTheme() {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme') || 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  }

  function updateButtonUI() {
    const theme = document.documentElement.getAttribute('data-theme');
    document.querySelectorAll('.theme-toggle').forEach((btn) => {
      btn.setAttribute('aria-pressed', String(theme === 'dark'));
    });
  }

  function applyStoredTheme(doc: Document) {
    let theme = localStorage.getItem('theme');
    if (!theme) {
      theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    doc.documentElement.setAttribute('data-theme', theme);
  }

  function init() {
    updateButtonUI();
    document.querySelectorAll('.theme-toggle').forEach((btn) => {
      btn.addEventListener('click', toggleTheme);
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', (e: Event) => {
    applyStoredTheme((e as any).newDocument);
  });
</script>
