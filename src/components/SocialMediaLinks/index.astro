---
import GitHubLogo from "./assets/github.svg";
import TelegramLogo from "./assets/telegram.svg";
import VKLogo from "./assets/VK.svg";

const logoSize = 36;
---

<style>
  .links {
    display: flex;
    list-style: none;
    gap: var(--space-4);
    justify-content: center;
  }

  .link > svg {
    transition: scale var(--transition-duration-2);
  }

  .link--github {
    display: inline-flex;
    border-radius: 50%;
    background-color: var(--color-bg-elevated);
    color: var(--color-text-primary);
    transition: scale var(--transition-duration-2);
  }

  .link--github > svg {
    display: block;
  }

  .link > svg:hover {
    scale: 1.1;
  }

  .link--github:hover {
    scale: 1.1;
  }
</style>

<ul class="links">
  <li>
     <a href="https://github.com/atlz253" title="GitHub" class="link link--github"
      ><GitHubLogo width={logoSize} height={logoSize} /></a
    >
  </li>
  <li>
    <a href="https://t.me/+ONmOoTgmeDgxOWYy" title="Telegram" class="link"
      ><TelegramLogo width={logoSize} height={logoSize} /></a
    >
  </li>
  <li>
    <a href="https://vk.com/falexeev2014" title="VK" class="link"
      ><VKLogo width={logoSize} height={logoSize} /></a
    >
  </li>
</ul>
