---
import YandexMetrikaCounter from "./Yandex/YandexMetrikaCounter.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
---

<style>
  .main {
    display: flex;
    gap: var(--space-6);
    flex-direction: column;
    padding: var(--space-4);
  }

  .layout {
    display: grid;
    min-height: calc(100vh - var(--space-2));
    grid-template-rows: auto 1fr auto;
  }
</style>

<body>
  <div class="layout">
    <Header />
    <main class="main">
      <slot />
    </main>
    <Footer />
  </div>
  <YandexMetrikaCounter />
</body>
