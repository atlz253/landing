---
import Card from "../Card.astro";
import SocialMediaLinks from "../SocialMediaLinks/index.astro";
---

<style>
  .container {
    display: flex;
    justify-content: center;
    margin: var(--space-6);
  }

  .center {
    display: flex;
    gap: var(--space-5);
    flex-direction: column;
  }

  .name {
    font-size: 32px;
  }

  .posts {
    display: flex;
    font-size: 10px;
    font-weight: 500;
    gap: var(--space-5);
    color: var(--color-grey-8);
    justify-content: center;
  }

  @media (min-width: 520px) {
    .name {
      font-size: 56px;
    }

    .posts {
      font-size: 16px;
    }
  }
</style>

<Card>
  <div class="container">
    <div class="center">
      <h1 class="name">Федор Алексеев</h1>
      <ul class="posts">
        <li>Web-разработчик</li>
        <li>|</li>
        <li>Инженер-программист</li>
        <li>|</li>
        <li>Исследователь</li>
      </ul>
      <SocialMediaLinks />
    </div>
  </div>
</Card>

<script>
  const currentDate = new Date();
  if (currentDate.getDate() === 23 && currentDate.getMonth() === 10) {
    const name = document.querySelector(".name");
    const span = document.createElement("span");
    const birthYear = 2000;
    span.innerText = ` | ${currentDate.getFullYear() - birthYear} 🥳`;
    name?.appendChild(span);
  }
</script>
