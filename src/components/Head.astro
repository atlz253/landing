---
import GoogleFonts from "./GoogleFonts.astro";
import YandexMetrika from "./Yandex/YandexMetrika.astro";
import "../styles/index.css";
import { ClientRouter } from "astro:transitions";
import Favicon from "./Favicon/index.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  robots?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = "Портфолио Федора Алексеева: веб-разработка, инженерные проекты, музыка и контакты.",
  image,
  robots = "index, follow",
  structuredData,
} = Astro.props;

const pageTitle = [title, "Федор Алексеев"].filter((p) => p).join(" | ");
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const socialImageUrl = image ? new URL(image, Astro.site).href : undefined;
const structuredDataJson = structuredData
  ? JSON.stringify(structuredData).replace(/</g, "\\u003c")
  : undefined;
---

<script is:inline>
  (function() {
    var theme = localStorage.getItem('theme');
    if (!theme) {
      theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonicalUrl} />
<Favicon />
<title>{pageTitle}</title>
<meta property="og:locale" content="ru_RU" />
<meta property="og:site_name" content="Федор Алексеев" />
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
{socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
<meta name="twitter:card" content={socialImageUrl ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
{
  structuredDataJson && (
    <script is:inline type="application/ld+json" set:html={structuredDataJson} />
  )
}
<YandexMetrika />
<GoogleFonts />
<ClientRouter />
