---
import GoogleFonts from "./GoogleFonts.astro";
import YandexMetrika from "./Yandex/YandexMetrika.astro";
import "../styles/index.css";
import { ClientRouter } from "astro:transitions";
import Favicon from "./Favicon/index.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;

const pageTitle = [title, "Федор Алексеев"].filter((p) => p).join(" | ");
---

<script is:inline>
  (function() {
    var theme = localStorage.getItem('theme');
    if (!theme) {
      theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta
  name="description"
  content="Это сайт Федора Алексеева, на котором он рассказывает о себе"
/>
<Favicon />
<title>{pageTitle}</title>
<YandexMetrika />
<GoogleFonts />
<ClientRouter />
